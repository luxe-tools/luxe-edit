{
  "name": "luxe-edit-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "yarn workspace luxe-edit build",
    "dev": "yarn workspace demo dev",
    "build:demo": "yarn workspace demo build",
    "publish:core": "cd packages/core && npm publish --registry=https://registry.npmjs.org/",
    "publish:core:dry": "cd packages/core && npm pack --dry-run"
  },
  "repository": {
    "type": "git",
     "url": "https://github.com/luxe-tools/luxe-edit.git"
  },
  "bugs": {
    "url": "https://github.com/luxe-tools/luxe-edit/issues"
  },
  "homepage": "https://github.com/luxe-tools/luxe-edit#readme",
  "author": "amin uddin",
  "license": "MIT"
}
